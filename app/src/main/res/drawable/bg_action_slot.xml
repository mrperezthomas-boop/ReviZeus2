<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#F4DAB779" android:endColor="#E5B980" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#8E6D36" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#F1D8B17D" android:endColor="#E8C895" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#8E6D36" />
        </shape>
    </item>
</selector>
