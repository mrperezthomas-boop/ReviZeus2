<?xml version="1.0" encoding="utf-8"?>
<!--
    gradient_bottom_vignette.xml
    Drawable XML — dégradé transparent en haut → noir semi-transparent en bas.
    Utilisé comme vignette de lisibilité sur les cartes item_avatar.xml.
    Emplacement : res/drawable/gradient_bottom_vignette.xml
    Aucune image binaire requise — 100% XML.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#00000000"
        android:endColor="#CC000000" />
</shape>