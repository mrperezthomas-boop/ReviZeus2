<?xml version="1.0" encoding="utf-8"?>
<!--
    BOUTON PROMÉTHÉE — Style spécial avec effet flamme
    Couleur Ambre Doré #FFBF00
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- État pressé -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFBF00" />
            <stroke android:width="2dp" android:color="#FFBF00" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- État normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1AFFBF00" />
            <stroke android:width="1dp" android:color="#80FFBF00" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>