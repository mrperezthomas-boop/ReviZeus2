<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#33FFD700" /> <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0F0F1A" /> <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#44FFD700" />
        </shape>
    </item>
</selector>