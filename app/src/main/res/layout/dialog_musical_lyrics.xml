<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:background="@drawable/bg_rpg_dialog"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imgGodLyrics"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvLyricsTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:text="Temple SUNO et Karaoké Divin » 🚀🎶"
                    android:textColor="#FFD700"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chanson structurée + style à copier dans Suno Producteur de Disques d'Or(acles)"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFD700"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAROLES DE CHANSON"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1FFFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvLyricsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F0F0F0"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"
            android:fontFamily="serif"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STYLE POUR SUNO"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1FFFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLyricsStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#A5D6FF"
            android:textSize="13sp"
            android:textStyle="italic"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FORMULE CLÉE"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1FFFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLyricsMnemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCFFD700"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTION CONSEILLÉE"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1FFFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLyricsAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F3E6B3"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUIDE D'APOLLON"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1FFFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvApolloGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F0F0F0"
            android:textSize="14sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnCopyLyrics"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_temple_button"
                android:gravity="center"
                android:text="📜 PAROLES"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCopyStyle"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_temple_button"
                android:gravity="center"
                android:text="🎼 STYLE"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnCopySunoPack"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_temple_button"
                android:gravity="center"
                android:text="☀️ PACK SUNO"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnExportLyrics"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_temple_button"
                android:gravity="center"
                android:text="💾 EXPORT"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnApolloHelp"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_temple_button"
            android:gravity="center"
            android:text="🪽 AIDE PAS À PAS"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnLyricsClose"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_textelayout"
            android:gravity="center"
            android:text="FERMER"
            android:textColor="@android:color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
