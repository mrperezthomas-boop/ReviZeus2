<?xml version="1.0" encoding="utf-8"?>
<!--
    item_account_card.xml — Correctif ciblé v2
    - conservation de la carte de base
    - nom du héros à la place de l'ancien bloc niveau
    - niveau au-dessus de l'avatar
    - email visible
    - fragments en 2 lignes de 5 horizontalement
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:minHeight="100dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Fond conservé -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:alpha="0.55"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/bg_rpg_dialog" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Colonne avatar avec niveau au-dessus -->
        <LinearLayout
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvCardLevel"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:minWidth="72dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_temple_button"
                android:fontFamily="@font/cinzel"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:singleLine="true"
                android:text="LVL 1"
                android:textColor="#FFC107"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/ivCardAvatar"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/avatar_hero1" />
        </LinearLayout>

        <!-- Colonne infos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nom du héros -->
            <TextView
                android:id="@+id/tvCardPseudo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/cinzel_bold"
                android:maxLines="1"
                android:text="Nom du héros"
                android:textColor="@color/incorrect_text"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFD700"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvCardEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/exo2"
                android:maxLines="1"
                android:text="email@exemple.com"
                android:textColor="#F4E7B7"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvCardPlayTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2"
                android:text="⏱ —"
                android:textColor="#E0C97F"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvCardSavoirs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2"
                android:text="📚 0 savoir"
                android:textColor="#BBDDFF"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivCardEclatsIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_currency_eclat_savoir" />

                <TextView
                    android:id="@+id/tvCardEclats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/exo2"
                    android:text="0 Éclats"
                    android:textColor="#AADDFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivCardAmbroisieIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_currency_ambroisie" />

                <TextView
                    android:id="@+id/tvCardAmbroisie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/exo2"
                    android:text="0 Ambroisie"
                    android:textColor="#AAFFCC"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Fragments : 2 lignes de 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentZeus"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_zeus" />
                        <TextView
                            android:id="@+id/tvFragmentZeus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentAthena"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_athena" />
                        <TextView
                            android:id="@+id/tvFragmentAthena"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentPoseidon"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_poseidon" />
                        <TextView
                            android:id="@+id/tvFragmentPoseidon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentAres"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_ares" />
                        <TextView
                            android:id="@+id/tvFragmentAres"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentAphrodite"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_aphrodite" />
                        <TextView
                            android:id="@+id/tvFragmentAphrodite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentHermes"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_hermes" />
                        <TextView
                            android:id="@+id/tvFragmentHermes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentDemeter"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_demeter" />
                        <TextView
                            android:id="@+id/tvFragmentDemeter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentHephaistos"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_hephaistos" />
                        <TextView
                            android:id="@+id/tvFragmentHephaistos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentApollon"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_apollon" />
                        <TextView
                            android:id="@+id/tvFragmentApollon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivFragmentPromethee"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fragment_promethee" />
                        <TextView
                            android:id="@+id/tvFragmentPromethee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:fontFamily="@font/exo2"
                            android:text="0"
                            android:textColor="#FFD78A"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/cinzel_bold"
            android:text="▶"
            android:textColor="#FFD700"
            android:textSize="18sp" />
    </LinearLayout>
</FrameLayout>
