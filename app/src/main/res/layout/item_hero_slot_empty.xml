<?xml version="1.0" encoding="utf-8"?>
<!--
    item_hero_slot_empty.xml — Carte slot vide
    Même gabarit général que item_hero_slot_card pour garder
    exactement la même lecture visuelle.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:minHeight="100dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:alpha="0.55"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/bg_rpg_dialog" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvEmptySlotLabel"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_temple_button"
                android:fontFamily="@font/cinzel"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:singleLine="true"
                android:text="SLOT 1"
                android:textColor="#FFC107"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvEmptyPlus"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:text="+"
                android:textColor="#55FFD700"
                android:textSize="48sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEmptyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cinzel_bold"
                android:text="Emplacement libre"
                android:textColor="@color/incorrect_text"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFD700"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvEmptyBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2"
                android:text="Crée un nouveau héros sur ce compte pour remplir ce slot."
                android:textColor="#F4E7B7"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <FrameLayout
                android:id="@+id/btnCreateHero"
                android:layout_width="96dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_temple_button" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.30"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_textelayout" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="CRÉER\nHÉROS"
                    android:textColor="#FFD700"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/cinzel_bold"
            android:text="▶"
            android:textColor="#FFD700"
            android:textSize="18sp" />
    </LinearLayout>
</FrameLayout>
