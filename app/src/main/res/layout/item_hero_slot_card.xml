<?xml version="1.0" encoding="utf-8"?>
<!--
    item_hero_slot_card.xml — Carte héros occupé
    Basée visuellement sur item_account_card :
    - niveau au-dessus de l'avatar
    - nom du héros dans la colonne de droite
    - proportions proches, sans refonte géante
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:minHeight="100dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:alpha="0.55"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/bg_rpg_dialog" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvSlotLevel"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_temple_button"
                android:fontFamily="@font/cinzel"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:singleLine="true"
                android:text="LVL 1"
                android:textColor="#FFC107"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/ivSlotAvatar"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/avatar_hero1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotPseudo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/cinzel_bold"
                android:maxLines="1"
                android:text="Nom du héros"
                android:textColor="@color/incorrect_text"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFD700"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvSlotLine1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/exo2"
                android:maxLines="1"
                android:text="Slot 1"
                android:textColor="#F4E7B7"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvSlotPlayTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2"
                android:text="⏱ —"
                android:textColor="#E0C97F"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvSlotSavoirs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2"
                android:text="📚 0 savoir"
                android:textColor="#BBDDFF"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_currency_eclat_savoir" />

                <TextView
                    android:id="@+id/tvSlotEclats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/exo2"
                    android:text="0 Éclats"
                    android:textColor="#AADDFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_currency_ambroisie" />

                <TextView
                    android:id="@+id/tvSlotAmbroisie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/exo2"
                    android:text="0 Ambroisie"
                    android:textColor="#AAFFCC"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSlotHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2"
                android:text="Appui long : options"
                android:textColor="#C8B37A"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/cinzel_bold"
            android:text="▶"
            android:textColor="#FFD700"
            android:textSize="18sp" />
    </LinearLayout>
</FrameLayout>
