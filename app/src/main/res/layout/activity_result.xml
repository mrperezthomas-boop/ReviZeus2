<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A">

    <ImageView
        android:id="@+id/ivBackgroundResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.2"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_olympus_dark" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/layoutActions"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivImagePreview"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginBottom="16dp"
                android:background="#1AFFFFFF"
                android:scaleType="centerInside"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutSummaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_rpg_dialog"
                android:orientation="vertical"
                android:padding="14dp">

                <View
                    android:id="@+id/viewSummaryAccent"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="#FFD700" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgResultGod"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="Portrait du dieu du résumé"
                        android:scaleType="fitCenter"
                        android:src="@drawable/avatar_zeus_dialog" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvResultTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cinzel_bold"
                            android:text="⚡ Résumé divin"
                            android:textColor="#FFD700"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvResultSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/exo2"
                            android:text="Lecture sacrée"
                            android:textColor="#FFF3B0"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/exo2"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="#FFD700" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/exo2"
            android:text="L'Olympe analyse ton parchemin..."
            android:textColor="#FFD700"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="-16dp">

        <Button
            android:id="@+id/btnInvoke"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#FFD700"
            android:fontFamily="@font/cinzel"
            android:text=" ⚡ Offrande aux Oracles ⚡"
            android:textColor="#000000"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStartQuiz"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#2E7D32"
            android:fontFamily="@font/cinzel"
            android:text="STOCKER ET LANCER LE QUIZ 🏛️"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#B71C1C"
            android:fontFamily="@font/cinzel"
            android:text="🔁 REFAIRE"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutGodSaveOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_rpg_dialog"
        android:elevation="20dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/viewGodAccent"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#FFD700" />

        <LinearLayout
            android:id="@+id/layoutGodSaveCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imgGodSave"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="Portrait du dieu"
                android:scaleType="fitCenter"
                android:src="@drawable/avatar_zeus_dialog" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGodSaveName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cinzel_bold"
                    android:text="ZEUS"
                    android:textColor="#FFD700"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvGodSaveSpeech"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/exo2"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    tools:text="Mortel, nomme ce parchemin comme il se doit." />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="10dp"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutMatterChoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical" />
        </ScrollView>

        <EditText
            android:id="@+id/etCourseTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_rpg_dialog"
            android:fontFamily="@font/exo2"
            android:hint="Nom du parchemin"
            android:inputType="textCapSentences"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#BFBFBF"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGodCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#5B2020"
                android:fontFamily="@font/cinzel"
                android:text="Annuler"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnGodConfirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#C79A2B"
                android:fontFamily="@font/cinzel"
                android:text="Graver ce nom"
                android:textColor="#111111"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!--
        OVERLAY ORACLE PLEIN ÉCRAN :
        Ce conteneur est placé tout à la fin du root, donc au-dessus
        de toutes les autres couches (aperçu, loading, actions, dialogue).
        C'est lui qui porte tout l'effet visuel du scan.
    -->
    <FrameLayout
        android:id="@+id/oracleScanOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Halo global du scan -->
        <View
            android:id="@+id/scanFxOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="#1416D9FF"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

        <!-- Flash divin de départ -->
        <View
            android:id="@+id/scanFlash"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="#66E8FCFF"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

        <!--
            Le rayon de scan vit dans l'overlay Oracle.
            Il ne peut plus être "derrière" l'aperçu du document.
        -->
        <View
            android:id="@+id/scan_line"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:alpha="1"
            android:background="@drawable/bg_laser_scan"
            android:clickable="false"
            android:elevation="100dp"
            android:focusable="false"
            android:visibility="gone" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>