<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:orientation="vertical"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="57dp"
            android:adjustViewBounds="true"
            android:alpha="0.85"
            android:scaleType="fitXY"
            android:src="@drawable/bg_divine_card" />

        <TextView
            android:id="@+id/tvTrackTitle"
            android:layout_width="400dp"
            android:layout_height="match_parent"
            android:fontFamily="@font/cinzel_bold"
            android:paddingStart="30dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="Titre"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvTrackDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/exo2"
        android:text="Description"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvTrackActive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/cinzel"
        android:text="♫ PISTE ACTIVE"
        android:textColor="#FFD700"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPlayTrack"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_temple_button_inset"
            android:fontFamily="@font/cinzel"
            android:text="▶ PLAY"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStopTrack"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_temple_button_inset"
            android:fontFamily="@font/cinzel"
            android:text="⏹ ARRÊT"
            android:textColor="#FF4444"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
