<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rpg_dialog"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvEncounterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rencontre"
            android:textColor="#FFD700"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEncounterType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Type"
            android:textColor="#FFE5B4"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvEncounterGod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Guide divin"
            android:textColor="#FFD700"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvEncounterDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Description du node."
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEncounterMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Message RPG."
            android:textColor="#FFE5B4"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEncounterBack"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/bg_temple_button"
                android:text="Retour"
                android:textAllCaps="false"
                android:textColor="#1A0A00"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEncounterValidate"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_temple_button"
                android:text="Valider la rencontre"
                android:textAllCaps="false"
                android:textColor="#1A0A00"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
