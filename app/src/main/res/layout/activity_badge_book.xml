<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07070E">

    <RelativeLayout
        android:id="@+id/headerBadgeBook"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_divine_card">

        <TextView
            android:id="@+id/btnBackBadgeBook"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:text="←"
            android:textColor="#EAD8A3"
            android:textSize="26sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/cinzel_bold"
            android:text="LIVRE DES BADGES"
            android:textColor="#FFD700"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvBadgeBookResume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/vt323_regular"
            android:text="0 / 0"
            android:textColor="@color/ic_launcher_background"
            android:textSize="22sp" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerBadgeBook"
        android:clipToPadding="false"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/containerBadgeBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp" />

    </ScrollView>

</RelativeLayout>