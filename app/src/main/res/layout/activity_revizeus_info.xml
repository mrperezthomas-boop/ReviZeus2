<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootRevizeusInfo"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerViewInfo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        app:resize_mode="zoom"
        app:show_buffering="never"
        app:use_controller="false" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#8A05050A" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/bg_temple_button" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:fontFamily="@font/cinzel_bold"
                android:gravity="center"
                android:text="RÉVIZEUS — LE MYTHE"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_temple_button" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.35"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_textelayout" />

                <Button
                    android:id="@+id/btnInfoRetour"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/cinzel_bold"
                    android:text="RETOUR"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_temple_button" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.30"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_textelayout" />

                <Button
                    android:id="@+id/btnInfoNextBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/cinzel_bold"
                    android:text="AUTRE FOND"
                    android:textColor="#1A0A00"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:alpha="0.5"
            android:background="@drawable/bg_rpg_dialog"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cinzel_bold"
                android:text="📜 PARCHEMIN DU DESTIN"
                android:textColor="#FFD700"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/tvInfoContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/exo2"
                    android:lineSpacingExtra="4dp"
                    android:text="Chargement du mythe..."
                    android:textColor="#F5F1E8"
                    android:textSize="14sp" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
