<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A">

    <ImageView
        android:id="@+id/ivProfileBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.55"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_hero_profile" />

    <RelativeLayout
        android:id="@+id/layoutProfileHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_divine_card"
        android:elevation="12dp">

        <TextView
            android:id="@+id/btnBackProfile"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:text="←"
            android:textColor="#EAD8A3"
            android:textSize="26sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/cinzel_bold"
            android:text="STÈLE DU HÉROS"
            android:textColor="#FFD700"
            android:textSize="18sp" />
    </RelativeLayout>

    <ScrollView
        android:id="@+id/scrollHeroProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutProfileHeader"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_panel"
                android:elevation="8dp"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <FrameLayout
                            android:layout_width="118dp"
                            android:layout_height="118dp"
                            android:layout_alignParentStart="true">

                            <ImageView
                                android:id="@+id/ivProfileAvatarFrame"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter"
                                android:scaleX="2"
                                android:scaleY="2"
                                android:src="@drawable/frame_avatar_gold" />

                            <ImageView
                                android:id="@+id/ivProfileAvatar"
                                android:layout_width="150dp"
                                android:layout_height="150dp"
                                android:layout_gravity="center"
                                android:scaleType="centerInside"
                                android:scaleX="0.7"
                                android:scaleY="0.7"
                                android:src="@android:drawable/sym_def_app_icon" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="126dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvProfileName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/cinzel_bold"
                                android:text="NOM DU HÉROS"
                                android:textColor="@color/design_default_color_error"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/tvProfileRang"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/exo2"
                                android:text="Mortel"
                                android:textColor="@color/ambre_promethee"
                                android:textSize="20sp" />

                            <TextView
                                android:id="@+id/tvProfileTitre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/cinzel"
                                android:text=""
                                android:textColor="#B98AFF"
                                android:textSize="11sp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvProfileClasse"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/exo2"
                                android:text="Terminale"
                                android:textColor="#9D9076"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvProfileLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/vt323_regular"
                                android:text="LVL 1"
                                android:textColor="#5FB3FF"
                                android:textSize="30sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <View
                        android:id="@+id/viewHeroAccent"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="10dp"
                        android:background="#FFD700" />

                    <ProgressBar
                        android:id="@+id/pbProfileXp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="#2A2000"
                        android:progressTint="#FFD700" />

                    <TextView
                        android:id="@+id/tvProfileXp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0 / 500 XP"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivCurrencyEclatProfile"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:contentDescription="Éclats"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_currency_eclat_savoir" />

                            <TextView
                                android:id="@+id/tvProfileEclats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:fontFamily="@font/vt323_regular"
                                android:text="0"
                                android:textColor="#FFE58A"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivCurrencyAmbroisieProfile"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:contentDescription="Ambroisie"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_currency_ambroisie" />

                            <TextView
                                android:id="@+id/tvProfileAmbroisie"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:fontFamily="@font/vt323_regular"
                                android:text="0"
                                android:textColor="#E7C8FF"
                                android:textSize="20sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/btnBadgeBook"
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_action_slot"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginBottom="4dp"
                            android:scaleType="fitCenter"
                            android:scaleX="2"
                            android:scaleY="2"
                            android:src="@drawable/ic_badge_book_olympian" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cinzel_bold"
                            android:text="BADGES"
                            android:textColor="@color/design_default_color_primary_dark"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnInventory"
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_action_slot"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginBottom="4dp"
                            android:scaleType="fitCenter"
                            android:scaleX="2"
                            android:scaleY="2"
                            android:src="@drawable/ic_inventory_bag_olympian" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cinzel_bold"
                            android:text="SAC"
                            android:textColor="@color/design_default_color_primary"
                            android:textSize="14sp" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardDayStreak"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card_hero"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_day_streak_olympian" />

                    <TextView
                        android:id="@+id/tvProfileDayStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cinzel"
                        android:text="JOUR"
                        android:textColor="@color/design_default_color_primary_dark"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardBestDayStreak"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card_hero"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_day_streak_olympian" />

                    <TextView
                        android:id="@+id/tvProfileBestDayStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cinzel"
                        android:text="Best DayStreak"
                        android:textColor="#A88E5A"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardWinStreak"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card_hero"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_win_streak_olympian" />

                    <TextView
                        android:id="@+id/tvProfileWinStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cinzel"
                        android:text="VICTOIRE"
                        android:textColor="@color/design_default_color_secondary"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardBestWinStreak"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card_hero"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_win_streak_olympian" />

                    <TextView
                        android:id="@+id/tvProfileBestWinStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cinzel"
                        android:text="Best WinStreak"
                        android:textColor="@color/material_dynamic_tertiary20"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSucces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_hero_panel"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/cinzel_bold"
                        android:text="LIVRE DES SUCCÈS"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvBadgesResume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0 / 0"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="22sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbBadgesProgression"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="#2A2000"
                    android:progressTint="#FFD700" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_prestige_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/ivBadgePrestige"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/badge_locked" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cinzel"
                            android:text="TROPHÉE DE PRESTIGE"
                            android:textColor="#A88E5A"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvBadgePrestigeNom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/cinzel_bold"
                            android:text="Aucun trophée encore"
                            android:textColor="@color/black"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvBadgePrestigeRarete"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/exo2"
                            android:text=""
                            android:textColor="#C0C0C0"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSecondaires"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_hero_panel"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cinzel_bold"
                    android:text="STATISTIQUES"
                    android:textColor="@color/design_default_color_error"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card_hero"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvProfileTotalXp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/vt323_regular"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cinzel"
                            android:text="XP TOTAL"
                            android:textColor="#A88E5A"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card_hero"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvProfileQuizCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/vt323_regular"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cinzel"
                            android:text="QUIZ"
                            android:textColor="#A88E5A"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_stat_card_hero"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProfileScanCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cinzel"
                        android:text="COURS SCANNÉS"
                        android:textColor="#A88E5A"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutNotifBadge"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_divine_card"
        android:elevation="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivNotifBadgeIcon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="fitCenter"
            android:src="@drawable/badge_locked" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cinzel"
                android:text="🏆 SUCCÈS DÉBLOQUÉ !"
                android:textColor="#FFD700"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvNotifBadgeNom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/cinzel_bold"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvNotifBadgeRarete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/exo2"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvNotifBadgeXp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/vt323_regular"
                    android:text=""
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btnNotifClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="✕"
            android:textColor="#806040"
            android:textSize="18sp" />
    </LinearLayout>

</RelativeLayout>
